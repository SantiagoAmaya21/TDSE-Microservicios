# Spring Boot Configuration Template

# Server Configuration
server.port=8080

# H2 Database Configuration (Development)
spring.datasource.url=jdbc:h2:mem:testdb
spring.datasource.driverClassName=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=password
spring.h2.console.enabled=true

# JPA Configuration
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
spring.jpa.hibernate.ddl-auto=create-drop
spring.jpa.show-sql=true

# Auth0 Configuration (Required)
auth0.domain=your-auth0-domain.auth0.com
auth0.audience=your-api-identifier

# Application Configuration
spring.application.name=twitter-like-app

# Logging Configuration
logging.level.com.tdse.twitter=INFO
logging.level.org.springframework.security=INFO

# Production Configuration (Uncomment for production)
# spring.datasource.url=jdbc:postgresql://your-db-host:5432/twitter_db
# spring.datasource.username=your-username
# spring.datasource.password=your-password
# spring.jpa.hibernate.ddl-auto=update
# spring.jpa.show-sql=false
